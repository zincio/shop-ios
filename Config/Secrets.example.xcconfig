// Copy this file to Config/Secrets.xcconfig and fill in real values.
// Secrets.xcconfig is gitignored.
//
// xcconfig gotcha: values are LITERAL — no quotes, and `//` starts a comment,
// so escape any `//` in a URL as `https:/$()/host`.

// ─── Signing & identity (per-developer) ──────────────────────────────────────
// Needed to install on a physical device. For the iOS Simulator you can leave
// these at their defaults (simulator builds skip code signing entirely).
//
// Your Apple Developer Team ID (Xcode ▸ Settings ▸ Accounts ▸ your team, or the
// 10-char code in your "Apple Development" signing certificate). Leave blank for
// simulator-only builds.
DEVELOPMENT_TEAM =
// Reverse-DNS prefix for the app's bundle IDs and App Group. The upstream
// io.zinc.zincshop identifiers are registered to Zinc's account, so to run on
// YOUR device pick a prefix you own (e.g. com.yourname.zincshop). The widget,
// test, and App Group identifiers are all derived from this.
APP_BUNDLE_PREFIX = io.zinc.zincshop

// ─── API keys & endpoints ────────────────────────────────────────────────────
// Apple Pay publishable key (safe to ship in-app). From your Stripe dashboard.
STRIPE_PUBLISHABLE_KEY = pk_test_replace_me
// Apple Pay merchant identifier. Must be registered under your team in the
// Apple Developer portal for on-device Apple Pay; match it to APP_BUNDLE_PREFIX.
APPLE_PAY_MERCHANT_ID = merchant.com.zinc.shopdemo
// Zinc API base URL.
ZINC_BASE_URL = https:/$()/api.zinc.com
// Zinc Bearer API key for cross-retailer search (demo). Leave blank to use the
// built-in demo catalog instead.
ZINC_API_KEY =
