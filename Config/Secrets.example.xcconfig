// Copy this file to Config/Secrets.xcconfig and fill in real values.
// Secrets.xcconfig is gitignored.
//
// Apple Pay publishable key (safe to ship in-app). From your Stripe dashboard.
STRIPE_PUBLISHABLE_KEY = pk_test_replace_me
// Apple Pay merchant identifier configured in the Apple Developer portal.
APPLE_PAY_MERCHANT_ID = merchant.com.zinc.shopdemo
// Zinc API base URL.
ZINC_BASE_URL = https:/$()/api.zinc.com
// Zinc Bearer API key for cross-retailer search (demo). Leave blank to use the
// built-in demo catalog instead.
ZINC_API_KEY =
